{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "share": "disabled",
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "python -m unittest*": "allow",
      "python scripts/*": "allow",
      "git push*": "ask",
      "git reset*": "deny",
      "rm -rf*": "deny"
    },
    "external_directory": "deny",
    "webfetch": "ask",
    "websearch": "ask"
  }
}
